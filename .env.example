# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a Git.

# Auth0 Client Secret
AUTH0_CLIENT_SECRET=tu_client_secret_aqui

# JWT secret propio de la app (Base64, mínimo 32 bytes)
# Generar con: openssl rand -base64 32
APP_JWT_SECRET=tu_clave_base64_aqui

# Base de datos
DB_URL=jdbc:postgresql://localhost:5432/lis_inventory
DB_USERNAME=postgres
DB_PASSWORD=postgres
